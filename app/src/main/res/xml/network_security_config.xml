<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext is still required for local cast servers, LAN proxies, and Together endpoints. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
