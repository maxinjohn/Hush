# Copy to local.properties and fill in optional API keys.
# local.properties is gitignored.

# Optional: Last.fm / Libre.fm scrobbling
# LASTFM_API_KEY=
# LASTFM_SECRET=

# Optional: ArchiveTune Canvas bearer token (canvas animated artwork)
# CANVAS_BEARER_TOKEN=

# Optional: Music Together bearer token
# TOGETHER_BEARER_TOKEN=

# Optional: nightly build metadata
# NIGHTLY_BUILD_HASH=

# Release signing — required for local release APKs (same key as CI).
# After ./gradlew assemble*Release, always run scripts/resign-release-apk.sh on the APK.
# Or use: bash scripts/build-release.sh [foss|gms] [mobile|tv] [abi]
# List all variants: bash scripts/build-release.sh list
# Without the resign step, some phones show "package appears to be invalid".
# STORE_PASSWORD=
# KEYSTORE_PASSWORD=
# KEY_ALIAS=hush
# KEY_PASSWORD=
